# Скопируйте в .env и заполните под себя. Файл .env в git не попадает.

# Порт API-сервера (vite dev-сервер проксирует /api сюда, см. vite.config.ts)
PORT=3001

# Секрет подписи JWT. В production обязателен, минимум 32 символа.
# Сгенерировать: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=

# Путь до файла SQLite (по умолчанию server/data/app.db)
# DATABASE_PATH=

# NODE_ENV=production
